rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    match /users/{userId} {
      // Any user reads their own doc
      allow read: if request.auth != null && request.auth.uid == userId;
      // Admins read all user docs
      allow read: if request.auth != null && userDoc().role == 'admin';

      // Admins write OTHER users' docs (block, unblock, promote, etc.)
      // userId != auth.uid means userDoc() reads a DIFFERENT doc — no circular read.
      allow write: if request.auth != null
                   && request.auth.uid != userId
                   && userDoc().role == 'admin';

      // A new professor creates their own doc on first sign-in
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == 'professor'
                    && request.resource.data.isBlocked == false;

      // An admin updates their OWN doc for role-switching (viewAs field).
      // Does NOT call userDoc() — avoids circular read on the same document.
      // Only allows touching viewAs, role, isAdmin — nothing sensitive.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['viewAs', 'role', 'isAdmin']);
    }

    match /logs/{logId} {
      // Professors (or admins acting as professor) read their own logs
      allow read: if request.auth != null
                  && resource.data.professorUid == request.auth.uid;
      // Admins read all logs
      allow read: if request.auth != null && userDoc().role == 'admin';

      // Professor creates a check-in log.
      // Also allows admin acting as professor (role='admin', viewAs='professor').
      // SERVER-SIDE: room must not be occupied.
      allow create: if request.auth != null
                    && request.resource.data.professorUid == request.auth.uid
                    && (userDoc().role == 'professor' || (userDoc().role == 'admin' && userDoc().viewAs == 'professor'))
                    && userDoc().isBlocked == false
                    && !exists(/databases/$(database)/documents/activeRooms/$(request.resource.data.roomNumber));

      // Professor updates only logoutAt on their own log
      allow update: if request.auth != null
                    && resource.data.professorUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['logoutAt'])
                    && (userDoc().role == 'professor' || (userDoc().role == 'admin' && userDoc().viewAs == 'professor'))
                    && userDoc().isBlocked == false;

      // Admins update any field (void / restore)
      allow update: if request.auth != null && userDoc().role == 'admin';
    }

    match /allowedEmails/{key} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && userDoc().role == 'admin';
    }

    match /auditLogs/{logId} {
      allow read:  if request.auth != null && userDoc().role == 'admin';
      allow write: if request.auth != null;
    }

    match /qrRooms/{roomId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && userDoc().role == 'admin';
    }

    match /activeRooms/{roomId} {
      allow read: if request.auth != null;

      // Professor (or admin acting as professor) can claim a room
      allow create: if request.auth != null
                    && request.resource.data.professorUid == request.auth.uid;

      // Occupying user or admin can free a room
      allow delete: if request.auth != null
                    && (resource.data.professorUid == request.auth.uid
                        || userDoc().role == 'admin');
    }
  }
}
